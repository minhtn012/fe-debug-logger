{
  "manifest_version": 3,
  "name": "FE Debug Logger",
  "version": "0.2.0",
  "description": "Capture frontend debug logs as structured Markdown for Claude Code",
  "permissions": ["activeTab", "storage", "downloads", "offscreen", "tabs", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "toggle-annotate": {
      "suggested_key": { "default": "Ctrl+Shift+A", "mac": "Command+Shift+A" },
      "description": "Toggle annotation inspect mode"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "capture/console-capture.js",
        "capture/user-action-capture.js",
        "capture/network-capture.js",
        "capture/component-state-capture.js",
        "capture/dom-snapshot-capture.js",
        "capture/annotation-capture.js",
        "capture/screenshot-capture.js",
        "content-script-main.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
